# ============================================================
# QQ Agent Bot — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Bot Identity ---
BOT_QQ=123456789                    # Your bot's QQ number
OWNER_QQ=987654321                  # Bot owner's QQ number
OWNER_NAME=YourName                 # Owner's display name

# --- NapCat Connection ---
NAPCAT_WS_URL=ws://127.0.0.1:3001  # NapCat OneBot WebSocket URL

# --- OpenClaw Gateway ---
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=18789                  # OpenClaw Gateway port
GATEWAY_TOKEN=your_gateway_token    # Gateway auth token

# --- HTTP Callback ---
CALLBACK_PORT=19283                 # HTTP callback port for Agent replies

# --- Monitored Groups ---
# Comma-separated group IDs to monitor
MONITORED_GROUPS=123456789,987654321
# Group display names (JSON format)
GROUP_NAMES={"123456789":"Group A","987654321":"Group B"}

# --- Intent Classifier (LLM API) ---
INTENT_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
INTENT_API_KEY=your_intent_api_key
INTENT_MODEL=qwen-plus

# --- Quick Reply Model ---
QUICK_API_URL=https://api.example.com/v1/chat/completions
QUICK_API_KEY=your_quick_api_key
QUICK_MODEL=your-model-name

# --- Feedback Monitor (Python scripts) ---
LLM_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
LLM_KEY=your_llm_api_key
LLM_MODEL=qwen-plus

# --- Data Directories ---
DATA_DIR=/home/your_user/.openclaw
WORKSPACE_DIR=/home/your_user/.openclaw/workspace

# --- Bot Personality ---
BOT_NAME=小助手                      # Bot's display name
BOT_PERSONA=你是一个友好的QQ群助手     # One-line persona description

# --- Node.js Path (for Python scripts calling node) ---
NODE_BIN=/usr/bin/node
